[Unit]
Description=Juhe WeCom Private CDN Web API
After=network-online.target wecdn-service.service
Wants=network-online.target
Requires=wecdn-service.service

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/wecdn_dist_v2.8.3/wecdn_web
ExecStart=/home/wecdn_dist_v2.8.3/wecdn_web/wecdn_web
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
