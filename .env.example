# DeepSeek uses an OpenAI-compatible chat completions API.
# Keep real credentials in .env only and never commit that file.
MODEL_API_KEY=
MODEL_BASE_URL=https://api.deepseek.com
MODEL_NAME=deepseek-chat
PORT=8080
DB_PATH=data/english_agent.db
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_TEST_USER_ID=
WECOM_SECRET=
WECOM_TOKEN=
WECOM_ENCODING_AES_KEY=
TRUST_PROXY_HEADERS=false
WECOM_API_TIMEOUT=10
